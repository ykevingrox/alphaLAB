# Copy this file to `.env` and fill in the real values. `.env` is gitignored.

# Aliyun Bailian OpenAI-compatible endpoint (DashScope).
# Docs: search "DashScope OpenAI compatibility" on help.aliyun.com
BIOTECH_ALPHA_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Your API key. Never commit the real value. DASHSCOPE_API_KEY also works.
BIOTECH_ALPHA_LLM_API_KEY=your-dashscope-api-key

# Default model id on Bailian. qwen3.6-plus is the current Qwen3 primary model;
# fall back to qwen-plus if the compatible-mode endpoint refuses the newer id.
BIOTECH_ALPHA_LLM_MODEL=qwen3.6-plus

# Optional: set to 1 to enable Bailian "deep thinking" (reasoning_content).
# Costs more tokens. Reasoning text is stored in the trace `extra`, not in
# the response body that agents parse.
# BIOTECH_ALPHA_LLM_ENABLE_THINKING=0

# Optional: cap the number of total LLM calls a single run is allowed to make.
# Leave unset for no cap.
# BIOTECH_ALPHA_LLM_CALL_BUDGET=20

# Optional: directory where LLM trace JSONL files are appended. Defaults to
# data/traces/ (gitignored).
# BIOTECH_ALPHA_LLM_TRACE_DIR=data/traces
